# Copy this file to backend/.env and fill values locally.
# Do not commit backend/.env.

OPENAIR_ENV=dev

# Supabase
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_SECRET_KEY=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_RAW_AUDIO_BUCKET=openair-raw-audio
R2_NORMALIZED_AUDIO_BUCKET=openair-normalized-audio
R2_PUBLIC_SIGNING_KEY_ID=
R2_PUBLIC_SIGNING_PRIVATE_KEY=

# AI moderation/transcription placeholder, to wire before real users.
AI_PROVIDER=
AI_API_KEY=

# Podcast Index (free) — for cold-start ingestion of open Podcasting 2.0 audio.
# Sign up at https://api.podcastindex.org. Used only by qa/tools/ingest_podcastindex.py.
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=
